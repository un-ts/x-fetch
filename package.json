{
  "name": "x-fetch",
  "version": "0.2.7",
  "type": "module",
  "description": "A simple but elegant `fetch` API wrapper with less than `880B` minified and brotlied, use `fetch` like a charm",
  "repository": "git+https://github.com/un-ts/x-fetch.git",
  "author": "JounQin <admin@1stg.me> (https://www.1stG.me)",
  "funding": "https://opencollective.com/x-fetch",
  "license": "MIT",
  "packageManager": "yarn@4.17.0",
  "engines": {
    "node": ">=14.0.0"
  },
  "main": "./lib/index.cjs",
  "types": "./index.d.cts",
  "module": "./lib/index.js",
  "exports": {
    "import": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "module-sync": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "require": {
      "types": "./index.d.cts",
      "default": "./lib/index.cjs"
    }
  },
  "files": [
    "index.d.cts",
    "lib",
    "!**/*.tsbuildinfo"
  ],
  "keywords": [
    "api",
    "fetch",
    "fetch-api",
    "node-fetch"
  ],
  "scripts": {
    "build": "run-p 'build:*'",
    "build:r": "r -f cjs",
    "build:tsc": "tsc -p src --declaration false && tsc -p src --emitDeclarationOnly true --removeComments false",
    "clean": "rimraf -g .type-coverage coverage dist lib '.*cache'",
    "dev": "vitest",
    "docs": "vite",
    "docs:build": "vite build",
    "format": "prettier --write .",
    "lint": "run-p 'lint:*'",
    "lint:es": "eslint . --cache --max-warnings 10",
    "lint:style": "stylelint . --cache",
    "lint:tsc": "tsc --noEmit",
    "prepare": "simple-git-hooks && yarn-berry-deduplicate || exit 0",
    "release": "yarn build && clean-pkg-json && changeset publish",
    "serve": "vite preview",
    "test": "vitest run",
    "typecov": "type-coverage"
  },
  "devDependencies": {
    "@1stg/browserslist-config": "^2.1.4",
    "@1stg/common-config": "^15.0.0",
    "@1stg/stylelint-config": "^6.2.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint-react/eslint-plugin": "^5.9.2",
    "@mdx-js/rollup": "^3.1.1",
    "@pkgr/rollup": "^7.1.0",
    "@shikijs/rehype": "^4.2.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web": "^0.0.350",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "clean-pkg-json": "^2.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "github-markdown-css": "^5.9.0",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.1.0",
    "stylelint": "^17.13.0",
    "type-coverage": "^2.29.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "yarn-berry-deduplicate": "^6.1.3"
  },
  "typeCoverage": {
    "atLeast": 100,
    "cache": true,
    "detail": true,
    "ignoreAsAssertion": true,
    "ignoreFiles": [
      "**/*.d.ts"
    ],
    "ignoreNonNullAssertion": true,
    "showRelativePath": true,
    "strict": true,
    "update": true
  }
}
